# Salin file ini menjadi .env lalu sesuaikan nilainya.
# .env TIDAK boleh di-commit (sudah masuk .gitignore).

# Kunci rahasia Flask. Buat nilai acak, misal dengan:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# development atau production
FLASK_ENV=development

# Path ke model Keras. Kosongkan untuk memakai default (app/ml/model_final_best.keras).
MODEL_PATH=

# Batas ukuran upload dalam byte (default 8388608 = 8 MB).
MAX_CONTENT_LENGTH=8388608

# 1 = muat model saat startup (default). Setel 0 pada server yang memuat aplikasi
# di proses induk lalu mem-fork pekerja (Passenger/cPanel): TensorFlow tidak aman
# terhadap fork dan model.predict() akan menggantung. Di cPanel hal ini sudah
# diatur otomatis oleh passenger_wsgi.py.
EAGER_LOAD_MODEL=1
